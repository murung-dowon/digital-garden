{%if settings.dgHomeLink === true%}
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" style="text-decoration: none;">
                {% if meta.siteLogoPath %}
                    <img class="site-logo" src="{{meta.siteLogoPath}}" alt="{{meta.siteName}}">
                {% else %}
                    <h1 style="margin: 15px !important;">{{meta.siteName}}</h1>
                {% endif %}
            </a>
        </div>
        <div class="navbar-profile">
            <img class="navbar-avatar" src="/img/avatar.png" alt="Dowon Kim" />
            <div class="navbar-profile-text">
                <span class="navbar-profile-name">Dowon Kim</span>
                <span class="navbar-profile-bio">Project Manager · Logistics | Robotics</span>
            </div>
            <div class="navbar-profile-links">
                <a href="https://linkedin.com/in/murung-dowon" target="_blank" rel="noopener noreferrer" title="LinkedIn">
                    <i data-lucide="linkedin"></i>
                </a>
                <a href="mailto:contact.murung@gmail.com" title="Email">
                    <i data-lucide="mail"></i>
                </a>
            </div>
        </div>
        {% if settings.dgEnableSearch === true%}
            {% include "components/searchButton.njk" %}
        {%endif%}
    </nav>
    {%else%}
    <div class="empty-navbar" >
        {% if settings.dgEnableSearch === true%}
            {% include "components/searchButton.njk" %}
        {%endif%}
    </div>
{%endif%}